# CHART 7: Leading-edge (<=5nm) fab capacity by country over time

leading = fab[(fab.fab_type == 'logic_leading') & (fab.process_node_nm <= 5)]
by_country = leading.groupby(['year', 'country_iso3'])['monthly_wafer_capacity'].sum().unstack(fill_value=0)
