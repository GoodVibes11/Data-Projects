# CHART 2: AI accelerator vendor market share, 2020 vs 2026

mkt = ai.groupby(['year', 'vendor'])['estimated_revenue_usd_m'].sum().unstack(fill_value=0)
share2020 = (mkt.loc[2020] / mkt.loc[2020].sum() * 100).sort_values(ascending=False)
share2026 = (mkt.loc[2026] / mkt.loc[2026].sum() * 100).sort_values(ascending=False)

fig, ax = plt.subplots(figsize=(10, 6))
vendors_order = share2026.index.tolist()
y = np.arange(len(vendors_order))
s2020 = [share2020.get(v, 0) for v in vendors_order]
s2026 = [share2026.get(v, 0) for v in vendors_order]

ax.barh(y + 0.19, s2020, height=0.36, color="#9DB4CE", label="2020")
