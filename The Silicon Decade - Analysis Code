bottom = np.zeros(len(by_country))
for c in by_country.columns:
    ax.bar(by_country.index, by_country[c], bottom=bottom, label=c, color=colors_geo.get(c, GREY), width=0.6)
    bottom += by_country[c].values

ax2 = ax.twinx()
twn_share = (by_country.get('TWN', 0) / by_country.sum(axis=1) * 100)
