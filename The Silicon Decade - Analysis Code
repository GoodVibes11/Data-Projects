# CHART 8: R&D vs Capex intensity bubble chart (2026, top companies)

latest = fin[fin.year == 2026].copy()
latest['rd_intensity'] = latest.rd_spend_usd_bn / latest.revenue_usd_bn * 100
latest['capex_intensity'] = latest.capex_usd_bn / latest.revenue_usd_bn * 100
top = latest.sort_values('revenue_usd_bn', ascending=False).head(16)

seg_colors = {
    'fabless_gpu': GREEN, 'fabless_cpu_gpu': GREEN, 'fabless_mobile': TEAL, 'fabless_diversified': TEAL,
    'foundry': NAVY, 'idm_memory': ORANGE, 'idm_cpu': GREY, 'equipment_litho': PURPLE,
    'equipment_diversified': PURPLE, 'equipment_etch': PURPLE, 'idm_analog': GOLD,
}

fig, ax = plt.subplots(figsize=(11, 7.5))
seen_coords = {}
for _, row in top.iterrows():
    c = seg_colors.get(row['segment'], GREY)
    ax.scatter(row['rd_intensity'], row['capex_intensity'], s=row['revenue_usd_bn']*7, color=c, alpha=0.65, edgecolor='white', linewidth=1.2)
    key = (round(row['rd_intensity'], 1), round(row['capex_intensity'], 1))
    n = seen_coords.get(key, 0)
    seen_coords[key] = n + 1
    yoff = 5 + n * 13
    ax.annotate(row['company_name'], (row['rd_intensity'], row['capex_intensity']), xytext=(8, yoff), textcoords='offset points', fontsize=8.7, fontweight='bold', color='#222222')

ax.set_xlabel("R&D spend as % of revenue", fontsize=10.5)
ax.set_ylabel("Capex spend as % of revenue", fontsize=10.5)
ax.set_title("Capital Intensity Map, 2026: Bubble size = revenue", fontsize=13, fontweight="bold", pad=14)
ax.spines[["top", "right"]].set_visible(False)
ax.grid(linestyle="--", alpha=0.3)
ax.text(0.98, 0.02, "Foundries & memory IDMs: capex-heavy\nFabless design houses: R&D-heavy, capex-light",
        transform=ax.transAxes, fontsize=8.5, color=GREY, style='italic', ha='right', va='bottom')
plt.tight_layout()
plt.savefig(OUT + "chart8_capital_intensity.png", dpi=200, bbox_inches="tight")
plt.close()

